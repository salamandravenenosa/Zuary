# ==========================================
# DentalMetrics — Variáveis de Ambiente
# ==========================================
# Copie para .env.local e preencha os valores

# --- Banco de Dados ---
DATABASE_URL="postgresql://user:password@localhost:5432/dentalmetrics?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="DentalMetrics"

# --- Criptografia de Tokens (AES-256-GCM) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# --- Meta / Instagram (Graph API) ---
# App no developers.facebook.com > Meta for Developers
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""

# --- Meta Pixel ---
META_PIXEL_ID=""

# --- Google OAuth (Analytics + Business Profile) ---
# Credenciais em console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=""

# --- TikTok ---
# App em developers.tiktok.com
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# --- WhatsApp Business API ---
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# --- Upstash Redis (Rate Limiting) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Cron Job ---
CRON_SECRET="gerar-com-openssl-rand-base64-32"

# --- Puppeteer (PDF) ---
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD="true"
